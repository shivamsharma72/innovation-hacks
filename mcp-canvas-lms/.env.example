# =============================================================================
# Canvas API (required for the MCP server to start)
# =============================================================================
# CANVAS_API_TOKEN — Personal access token from Canvas (Account > Settings >
# Approved Integrations > New Access Token). Sent on every request as:
#   Authorization: Bearer <token>
# The token decides which user/role Canvas sees (student vs teacher vs admin).
CANVAS_API_TOKEN=your_canvas_api_token_here

# CANVAS_DOMAIN — Hostname of your Canvas instance only (no https://, no path).
# Used to build the REST base URL: https://<CANVAS_DOMAIN>/api/v1
# Examples: school.instructure.com, canvas.myschool.edu
CANVAS_DOMAIN=your_domain.instructure.com

# Optional: process / logging
NODE_ENV=development
LOG_LEVEL=info

# Optional: retry behavior for 429 and 5xx (see CanvasClient in src/client.ts)
CANVAS_MAX_RETRIES=3
CANVAS_RETRY_DELAY=1000

# Parsed into server config; axios client timeout is still 30s in code unless changed
CANVAS_TIMEOUT=30000

# Transport: stdio = Cursor/Claude Desktop subprocess. streamable-http = HTTP (gateway, Docker).
# Academic Copilot gateway uses HTTP only — set streamable-http and match MCP_CANVAS_URL host/port.
MCP_TRANSPORT=streamable-http
MCP_HTTP_HOST=127.0.0.1
# Use a free port (Next.js often uses 3000). Gateway MCP_CANVAS_URL must match host:port/path.
MCP_HTTP_PORT=3001
MCP_HTTP_PATH=/mcp
# true = required for gateway: multiple POSTs per session (initialize, tools/list, …) on one transport.
# After each chat the client sends DELETE; the server resets session state for the next initialize.
MCP_HTTP_STATEFUL=true
MCP_HTTP_JSON_RESPONSE=true
# Comma-separated allowlist. Empty disables Origin checks.
MCP_HTTP_ALLOWED_ORIGINS=

# Optional: tests only (not read by loadConfigFromEnvironment / main server)
CANVAS_TEST_TOKEN=your_test_token_here
CANVAS_TEST_DOMAIN=test.instructure.com
