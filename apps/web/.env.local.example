# Copy to .env.local — never commit real secrets
#
# AUTH0_DOMAIN must be YOUR real tenant host from the Auth0 dashboard
# (e.g. dev-abc123.us.auth0.com). Do NOT leave "your-tenant" — discovery will fail.
# No https:// prefix — hostname only.
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=dev-xxxxxxxx.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
# Create an API in Auth0 Dashboard → Applications → APIs; use its Identifier
AUTH0_AUDIENCE=https://your-api-identifier

# Browser-visible (optional; API routes use GATEWAY_INTERNAL_URL when set)
NEXT_PUBLIC_GATEWAY_URL=http://127.0.0.1:8000

# Server-side only: FastAPI base URL (same as above for local dev)
GATEWAY_URL=http://127.0.0.1:8000

# On Vercel, set to your Fly/Railway gateway URL (not localhost)
# GATEWAY_INTERNAL_URL=https://gateway.example.com
