# Auth0 (must match the API Identifier you created in Auth0 → APIs)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Max assistant steps that may invoke tools (default 18; cap 64). Raise for long flows.
# OPENAI_MAX_TOOL_ROUNDS=32

# Browser URL for Workspace MCP OAuth (auth error messages point here)
# MCP_WORKSPACE_BROWSER_URL=http://localhost:8002

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# SQLite (default) or Postgres: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# Google OAuth for Workspace MCP (and Docker workspace-mcp). In Google Cloud → OAuth client add:
#   http://localhost:8002/oauth2callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Workspace MCP (Docker) also reads these if set; otherwise it uses GOOGLE_CLIENT_* above.
# Google Cloud → OAuth client must list http://localhost:8002/oauth2callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
#
# Workspace MCP + gateway chat: docker-compose forces MCP_ENABLE_OAUTH21=false so each
# chat’s new MCP session can still use tokens saved under WORKSPACE_MCP_CREDENTIALS_DIR.
# Set USER_GOOGLE_EMAIL to the same Google account you used at http://localhost:8002 OAuth
# so Gmail/Drive tools default correctly when the model omits user_google_email.
# USER_GOOGLE_EMAIL=you@gmail.com

# Comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Optional: Canvas MCP auth fallback (only if something invokes the agent without chat/onboarding).
# Normal chat uses the user's stored Canvas token + domain and sends X-Canvas-Token / X-Canvas-URL.
# CANVAS_API_TOKEN=
# CANVAS_DOMAIN=canvas.school.edu
# CANVAS_API_URL=https://canvas.school.edu/api/v1

# MCP (streamable HTTP). Required for gws__ / canvas__ tools in chat.
#
# Python canvas-mcp in ./canvas-mcp: ./scripts/run-canvas-mcp-local.sh (default :3001).
# Docker compose publishes canvas-mcp as 3001:3000.
MCP_CANVAS_URL=http://127.0.0.1:3001/mcp
MCP_GOOGLE_WORKSPACE_URL=http://127.0.0.1:8002/mcp
#
# If the gateway service runs INSIDE docker compose, compose overrides these to
# http://canvas-mcp:3000/mcp and http://workspace-mcp:8000/mcp — you can omit them in .env.
# MCP_MAX_TOOLS=120
# MCP_TOOL_DESCRIPTION_MAX_CHARS=400

# Dev: return tool_trace in POST /chat + log each tool_call at INFO
# CHAT_INCLUDE_TOOL_TRACE=true

# LOCAL ONLY — never enable in production
# SKIP_AUTH=true
